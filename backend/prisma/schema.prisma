// 情侣厨房数据模型
// 对应 docs/05-data-model.md
// 主键统一用 cuid，避免被遍历

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 用户与家庭空间
// ============================================================================

model User {
  id              String   @id @default(cuid())
  wxOpenid        String?  @unique @map("wx_openid")
  wxUnionid       String?  @map("wx_unionid")
  phone           String?  @unique @map("phone") @db.VarChar(20)
  passwordHash    String?  @map("password_hash") @db.VarChar(255)
  nickname        String   @default("情侣厨房用户")
  avatarUrl       String?  @map("avatar_url") @db.VarChar(500)
  gender          String?  @db.VarChar(10)
  signature       String?  @db.VarChar(200)
  currentFamilyId String?  @map("current_family_id")
  notificationPrefs Json   @default("{}") @map("notification_prefs")
  deletedAt       DateTime? @map("deleted_at") // 软注销
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // 关系
  currentFamily          Family?           @relation("CurrentFamily", fields: [currentFamilyId], references: [id])
  memberships            FamilyMember[]
  createdRecipes         Recipe[]
  ordersAsCustomer       Order[]           @relation("OrderCustomer")
  ordersAsChef           Order[]           @relation("OrderChef")
  orderMessages          OrderMessage[]
  ratings                Rating[]
  lovePointLogs          LovePointLog[]
  hiddenTimelineEntries  TimelineEntry[]   @relation("TimelineHider")
  timelineAsCustomer     TimelineEntry[]   @relation("TimelineCustomer")
  timelineAsChef         TimelineEntry[]   @relation("TimelineChef")
  recipeFavorites        RecipeFavorite[]
  feedbacks              Feedback[]
  businessConfigUpdates  BusinessConfig[]       @relation("BusinessConfigUpdatedBy")
  businessConfigChanges  BusinessConfigChange[] @relation("BusinessConfigChangeOperator")
  notificationLogs       NotificationLog[]
  aiUsageLogs            AiUsageLog[]

  @@index([wxOpenid])
  @@index([phone])
  @@index([deletedAt])
  @@map("user")
}

model Family {
  id                   String       @id @default(cuid())
  name                 String       @db.VarChar(60)
  relationType         String       @default("couple") @map("relation_type") @db.VarChar(20)
  anniversaryDate      DateTime?    @map("anniversary_date") @db.Date
  inviteCode           String?      @unique @map("invite_code") @db.VarChar(20)
  inviteCodeExpiresAt  DateTime?    @map("invite_code_expires_at")
  creatorUserId        String       @map("creator_user_id")
  status               String       @default("active") @db.VarChar(20)
  dissolvingAt         DateTime?    @map("dissolving_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  // 关系
  currentUsers    User[]          @relation("CurrentFamily")
  members         FamilyMember[]
  recipes         Recipe[]
  orders          Order[]
  lovePointLogs   LovePointLog[]
  timelineEntries TimelineEntry[]
  // Achievement 是多态关系（user / family），无 FK，通过 ownerType+ownerId 查询

  @@index([inviteCode])
  @@map("family")
}

model FamilyMember {
  id        String    @id @default(cuid())
  familyId  String    @map("family_id")
  userId    String    @map("user_id")
  role      String    @default("member") @db.VarChar(20)
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // MVP 阶段：同一用户活跃成员关系唯一
  // 应用层强制：先校验该 user 没有其他 leftAt = null 的记录
  @@index([familyId])
  @@index([userId])
  @@index([userId, leftAt])
  @@map("family_member")
}

// ============================================================================
// 菜谱
// ============================================================================

model Recipe {
  id              String   @id @default(cuid())
  familyId        String   @map("family_id")
  name            String   @db.VarChar(30)
  imageUrls       Json     @default("[]") @map("image_urls")
  difficulty      Int      @default(3) @db.SmallInt
  mealTags        Json     @default("[]") @map("meal_tags") // string[]
  flavorTags      Json     @default("[]") @map("flavor_tags") // string[]
  notes           String?  @db.VarChar(500)
  createdByUserId String   @map("created_by_user_id")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  orderCount      Int      @default(0) @map("order_count")
  avgRating       Float?   @map("avg_rating") @db.Float
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  family       Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  creator      User              @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  favorites    RecipeFavorite[]

  @@index([familyId, isDeleted])
  @@index([createdByUserId])
  @@map("recipe")
}

model RecipeFavorite {
  id        String   @id @default(cuid())
  recipeId  String   @map("recipe_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId, userId])
  @@index([userId])
  @@map("recipe_favorite")
}

// ============================================================================
// 订单
// ============================================================================

model Order {
  id                String    @id @default(cuid())
  familyId          String    @map("family_id")
  customerUserId    String    @map("customer_user_id")
  chefUserId        String    @map("chef_user_id")
  status            String    @db.VarChar(20)
  expectedServeAt   DateTime? @map("expected_serve_at")
  customerNotes     String?   @map("customer_notes") @db.VarChar(500)
  rejectReason      String?   @map("reject_reason") @db.VarChar(200)
  servedImageUrls   Json      @default("[]") @map("served_image_urls")
  totalLovePoints   Int       @default(0) @map("total_love_points")
  servedAt          DateTime? @map("served_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  customer User   @relation("OrderCustomer", fields: [customerUserId], references: [id], onDelete: Cascade)
  chef     User   @relation("OrderChef", fields: [chefUserId], references: [id], onDelete: Cascade)

  items          OrderItem[]
  messages       OrderMessage[]
  rating         Rating?
  lovePointLogs  LovePointLog[]
  achievements   Achievement[]
  timelineEntry  TimelineEntry?

  @@index([familyId, status])
  @@index([familyId, status, completedAt])
  @@index([customerUserId])
  @@index([chefUserId])
  @@map("order")
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String  @map("order_id")
  recipeId       String? @map("recipe_id")
  recipeSnapshot Json    @map("recipe_snapshot") // { name, imageUrls, difficulty, ... } 快照
  customNotes    String? @map("custom_notes") @db.VarChar(200)
  sortOrder      Int     @default(0) @map("sort_order")

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_item")
}

model OrderMessage {
  id           String   @id @default(cuid())
  orderId      String   @map("order_id")
  senderUserId String?  @map("sender_user_id") // 系统消息为 null
  type         String   @db.VarChar(20)
  content      Json     // 结构按 type 不同
  readAt       DateTime? @map("read_at")
  createdAt    DateTime @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User? @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_message")
}

model Rating {
  id               String   @id @default(cuid())
  orderId          String   @unique @map("order_id")
  raterUserId      String   @map("rater_user_id")
  stars            Int      @db.SmallInt
  comment          String?  @db.VarChar(500)
  imageUrls        Json     @default("[]") @map("image_urls")
  isAutoGenerated  Boolean  @default(false) @map("is_auto_generated")
  createdAt        DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rater User  @relation(fields: [raterUserId], references: [id], onDelete: Cascade)

  @@map("rating")
}

// ============================================================================
// 爱心币
// ============================================================================

model LovePointLog {
  id               String    @id @default(cuid())
  familyId         String    @map("family_id")
  userId           String    @map("user_id")
  changeAmount     Int       @map("change_amount")
  balanceAfter     Int       @map("balance_after")
  changeType       String    @map("change_type") @db.VarChar(30)
  sourceOrderId    String?   @map("source_order_id")
  description      String?   @db.VarChar(200)
  reversibleUntil  DateTime? @map("reversible_until")
  isReversed       Boolean   @default(false) @map("is_reversed")
  reversedFromId   String?   @unique @map("reversed_from_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  family       Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceOrder  Order?       @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)
  reversedFrom LovePointLog? @relation("LovePointReversal", fields: [reversedFromId], references: [id])
  reversedBy   LovePointLog? @relation("LovePointReversal")

  @@index([userId, createdAt])
  @@index([familyId, createdAt])
  @@map("love_point_log")
}

// ============================================================================
// 成就
// ============================================================================

model BadgeDefinition {
  id              String   @id @default(cuid())
  key             String   @unique @map("badge_key") @db.VarChar(50)
  title           String   @db.VarChar(30)
  description     String   @db.VarChar(100)
  emoji           String   @db.VarChar(10)
  category        String   @db.VarChar(20)
  /// owner 维度: user / family
  ownerType       String   @map("owner_type") @db.VarChar(20)
  /// 触发事件类型
  triggerType     String   @map("trigger_type") @db.VarChar(30)
  /// 评估器类型（决定如何判定解锁）
  evaluatorType   String   @map("evaluator_type") @db.VarChar(30)
  /// 评估器参数 JSON（不同 evaluatorType 有不同的 schema）
  evaluatorConfig Json     @map("evaluator_config")
  /// 是否为隐藏彩蛋
  hidden          Boolean  @default(false)
  /// 进度目标值（null 表示无进度条）
  progressTarget  Int?     @map("progress_target")
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  achievements Achievement[]

  @@index([isActive, triggerType, sortOrder])
  @@map("badge_definition")
}

model Achievement {
  id              String   @id @default(cuid())
  ownerType       String   @map("owner_type") @db.VarChar(20)
  ownerId         String   @map("owner_id") // user_id 或 family_id（多态，无 FK）
  badgeKey        String   @map("badge_key") @db.VarChar(50)
  sourceOrderId   String?  @map("source_order_id")
  metadata        Json     @default("{}")
  unlockedAt      DateTime @default(now()) @map("unlocked_at")

  sourceOrder      Order?           @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)
  badgeDefinition  BadgeDefinition? @relation(fields: [badgeKey], references: [key], onDelete: Restrict)

  // ownerId 是多态字段（可能指向 User 或 Family），不能加 FK
  // 应用层保证：删除 user/family 时同步清理对应 Achievement
  // 同 owner 同 badge_key 唯一
  @@unique([ownerType, ownerId, badgeKey])
  @@index([ownerType, ownerId])
  @@index([ownerType, ownerId, unlockedAt])
  @@map("achievement")
}

// ============================================================================
// 厨师等级
// ============================================================================

model ChefLevelDefinition {
  id           String   @id @default(cuid())
  key          String   @unique @map("level_key") @db.VarChar(30)
  title        String   @db.VarChar(20)
  emoji        String   @db.VarChar(10)
  minOrders    Int      @default(0) @map("min_orders")
  minAvgRating Decimal  @default(0) @map("min_avg_rating") @db.Decimal(3, 2)
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("chef_level_definitions")
}

// ============================================================================
// 时间线
// ============================================================================

model TimelineEntry {
  id               String   @id @default(cuid())
  familyId         String   @map("family_id")
  sourceType       String   @map("source_type") @db.VarChar(20)
  sourceOrderId    String?  @unique @map("source_order_id")
  occurredAt       DateTime @map("occurred_at")
  imageUrls        Json     @default("[]") @map("image_urls")
  customerUserId   String?  @map("customer_user_id")
  chefUserId       String?  @map("chef_user_id")
  customerComment  String?  @map("customer_comment") @db.VarChar(500)
  chefComment      String?  @map("chef_comment") @db.VarChar(500)
  hiddenByUserId   String?  @map("hidden_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  family       Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  sourceOrder  Order? @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)
  customerUser User?  @relation("TimelineCustomer", fields: [customerUserId], references: [id], onDelete: Cascade)
  chefUser     User?  @relation("TimelineChef", fields: [chefUserId], references: [id], onDelete: Cascade)
  hiddenByUser User?  @relation("TimelineHider", fields: [hiddenByUserId], references: [id], onDelete: Cascade)

  @@index([familyId, occurredAt])
  @@map("timeline_entry")
}

// ============================================================================
// 用户反馈
// ============================================================================

model Feedback {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id") // 可空：未登录用户也能反馈
  content   String   @db.VarChar(2000)
  contact   String?  @db.VarChar(200) // 联系方式（邮箱/微信号）
  status    String   @default("pending") @db.VarChar(20) // pending / processed / closed
  appVersion String? @map("app_version") @db.VarChar(50)
  platform  String?  @db.VarChar(50) // mp-weixin / admin / other
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId])
  @@map("feedback")
}

// ============================================================================
// 业务配置（运行时可编辑）
// ============================================================================

model BusinessConfig {
  groupKey      String   @id @map("group_key") @db.VarChar(64)
  value         Json
  schemaVersion Int      @default(1) @map("schema_version")
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedBy     String?  @map("updated_by")
  updatedByUser User?    @relation("BusinessConfigUpdatedBy", fields: [updatedBy], references: [id], onDelete: Cascade)

  @@map("business_config")
}

model BusinessConfigChange {
  id         String   @id @default(cuid())
  groupKey   String   @map("group_key") @db.VarChar(64)
  oldValue   Json     @map("old_value")
  newValue   Json     @map("new_value")
  operatorId String   @map("operator_id")
  operator   User     @relation("BusinessConfigChangeOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([groupKey, createdAt(sort: Desc)])
  @@map("business_config_change")
}

// ============================================================================
// 站内通知日志
// ============================================================================

model NotificationLog {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String    @db.VarChar(30)
  title     String    @db.VarChar(100)
  body      String    @db.VarChar(500)
  data      Json      @default("{}")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notification_log")
}

// ============================================================================
// AI
// ============================================================================

model AiConversation {
  id           String   @id @default(cuid())
  familyId     String   @map("family_id")
  userId       String   @map("user_id")
  type         String   @map("type") @db.VarChar(30) // cooking_assistant, recipe_gen, ...
  contextRefId String?  @map("context_ref_id") // orderId 等上下文 ID
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  messages AiConversationMessage[]

  @@index([familyId, userId])
  @@index([userId, createdAt])
  @@map("ai_conversation")
}

model AiConversationMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String   @db.VarChar(20) // system, user, assistant
  content        String   @db.Text
  tokenCount     Int      @default(0) @map("token_count")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_conversation_message")
}

model AiUsageLog {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  familyId         String   @map("family_id")
  provider         String   @db.VarChar(20)
  model            String   @db.VarChar(50)
  feature          String   @db.VarChar(30)
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  latencyMs        Int      @default(0) @map("latency_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature, createdAt])
  @@index([familyId, createdAt])
  @@index([feature, createdAt])
  @@map("ai_usage_log")
}
