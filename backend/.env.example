# 服务
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# 数据库
DATABASE_URL="mysql://family_kitchen:password@localhost:3306/family_kitchen?charset=utf8mb4"

# JWT
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=30d

# 微信小程序
WX_APPID=your-mini-program-appid
WX_APP_SECRET=your-mini-program-secret

# 微信订阅消息模板 ID
WX_TMPL_ORDER_ACCEPTED=
WX_TMPL_ORDER_SERVED=
WX_TMPL_ORDER_RUSHED=
WX_TMPL_ACHIEVEMENT=

# 对象存储（开发期：MinIO）
STORAGE_DRIVER=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=family-kitchen
MINIO_PUBLIC_BASE_URL=http://localhost:9000/family-kitchen

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# 日志
LOG_LEVEL=debug
# 设置后日志(JSON)会额外写入该文件，目录自动创建；留空则仅输出到控制台
# LOG_FILE=logs/app.log

# CORS
CORS_ORIGINS=http://localhost:5173

# 管理后台默认账号（MVP 用环境变量，后期换 admin_user 表）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
